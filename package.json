    "android:release:install:clean": "node tools/release-install.js --clean-on-mismatch",
    "android:release:install:emu": "node tools/release-install.js --device emulator-5554",
    "android:release:install:emu:clean": "node tools/release-install.js --device emulator-5554 --clean-on-mismatch"
  },
  "dependencies": {
    "@capacitor/app": "^8.0.0",
    "@capacitor/android": "^8.4.0",
